# Prompt Mestre Inicial
# Pedir o limite ao usuário
limite = int(input("Digite o valor máximo da sequência de Fibonacci: "))

# Inicializar a sequência
fibonacci = [0, 1]

# Gerar a sequência até o limite informado
while True:
    proximo = fibonacci[-1] + fibonacci[-2]
    
    if proximo > limite:
        break
    
    fibonacci.append(proximo)

# Exibir resultado
print("Sequência de Fibonacci até", limite, ":")
print(fibonacci)

